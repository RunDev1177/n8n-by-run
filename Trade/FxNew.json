    {
      "parameters": {
        "jsCode": "// ดึงข้อมูลทั้งหมดที่ส่งเข้ามา (มักจะเป็น Array ของ Objects)\nconst items = $input.all();\n\n// ใช้ .map() เพื่อสร้าง Array ใหม่ที่ผ่านการแปลงวันที่แล้ว\nconst result = items.map(item => {\n  const isoDate = item.json.date;\n  \n  if (!isoDate) return item; // ป้องกัน Error กรณีไม่มีข้อมูลวันที่\n\n  const date = new Date(isoDate);\n\n  // ใช้ sv-SE เพื่อให้ได้ฟอร์แมต YYYY-MM-DD HH:mm:ss\n  const formatted = date.toLocaleString(\"sv-SE\", {\n    timeZone: \"Asia/Bangkok\",\n  });\n\n  // แยก Date และ Time\n  const [datePart, timePart] = formatted.split(\" \");\n\n  return {\n    json: {\n      ...item.json,    // เก็บข้อมูลเดิมไว้ทั้งหมด\n      Date: datePart, // เพิ่มคอลัมน์ Date\n      Time: timePart  // เพิ่มคอลัมน์ Time\n    }\n  };\n});\n\nreturn result;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        272,
        208
      ],
