    {
      "parameters": {
        "jsCode": "// 1. ดึงวันที่ปัจจุบันและแปลงให้อยู่ในรูปแบบ YYYY-MM-DD\nconst today = new Date().toISOString().split('T')[0]; \n\nconst results = [];\n\nfor (const item of $input.all()) {\n  // 2. ตรวจสอบว่า Date ในข้อมูล (เช่น \"2026-04-13\") ตรงกับวันนี้หรือไม่\n  if (item.json.Date === today) {\n    // 3. เพิ่มฟิลด์ใหม่\n    item.json.myNewField = 1;\n    results.push(item);\n  }\n}\n\nreturn results;"
      },
