        "jsCode": "// ตัวอย่าง Code Node ใน n8n เพื่อตัด String ให้อยู่ในรูปตัวแปร\nconst text = $input.first().json.content.parts[0].text;\n\nreturn {\n  h4_trend: text.match(/H4_TREND:\\s*(.*)/)[1],\n  h1_trend: text.match(/H1_TREND:\\s*(.*)/)[1],\n  confluence: text.match(/CONFLUENCE:\\s*(.*)/)[1],\n  zone_type: text.match(/ZONE_TYPE:\\s*(.*)/)[1],\n  entry_price: text.match(/ENTRY_PRICE:\\s*(.*)/)[1],\n  sl_price: text.match(/SL_PRICE:\\s*(.*)/)[1],\n  tp1_price: text.match(/TP1:\\s*(.*)/)[1],\n  tp2_price: text.match(/TP2:\\s*(.*)/)[1],\n  tp3_price: text.match(/TP3:\\s*(.*)/)[1],\n  analyze_detail: text.match(/ANALYZE_DETAIL:\\s*(.*)/)[1]\n};"
