    {
      "parameters": {
        "jsCode": "// รับค่าเวลาปัจจุบัน และปรับให้อยู่ใน Timezone Asia/Bangkok (+07:00)\nconst now = new Date(new Date().toLocaleString('en-US', {timeZone: 'Asia/Bangkok'}));\nconst day = now.getDay(); // 0 = อาทิตย์, 1 = จันทร์, ..., 6 = เสาร์\nconst hour = now.getHours();\n\nlet isMarketOpen = true;\n\n// เช็คเงื่อนไขวันหยุดตลาด Forex (เวลาไทย)\nif (day === 0) {\n  // วันอาทิตย์ = ปิดทั้งวัน\n  isMarketOpen = false;\n} else if (day === 6 && hour >= 4) {\n  // วันเสาร์ ตั้งแต่ 04:00 น. เป็นต้นไป = ปิด\n  isMarketOpen = false;\n} else if (day === 1 && hour < 4) {\n  // วันจันทร์ ก่อน 04:00 น. = ปิด\n  isMarketOpen = false;\n}\n\nreturn {\n  isMarketOpen: isMarketOpen,\n  currentDay: day,\n  currentHour: hour,\n  status: isMarketOpen ? 'OPEN' : 'CLOSED'\n};\n"
      },
